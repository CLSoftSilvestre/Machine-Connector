PORT=3000
ENV=production
DB_PATH=./data/connector.db

# OPC-UA Configuration
OPCUA_ENDPOINT_URL=opc.tcp://your-server:4840
OPCUA_APP_NAME=MachineConnector
OPCUA_RECONNECT_DELAY=5000

# IIH Essentials Configuration
IIH_BASE_URL=http://iih-essentials
IIH_USERNAME=your-username
IIH_PASSWORD=your-password
IIH_POLL_INTERVAL_SECONDS=60
IIH_COUNTER_ENDPOINT=/IIHEssentials/v1/aggregatedvalues

# Apriso MES Configuration (stub - to be configured when API is ready)
APRISO_BASE_URL=http://apriso-mock:8080
APRISO_API_KEY=
APRISO_USERNAME=
APRISO_PASSWORD=

# Event Queue Configuration
QUEUE_RETENTION_HOURS=24
QUEUE_PROCESSING_INTERVAL_MS=10000
QUEUE_MAX_RETRIES=10
